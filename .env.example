# Cursor Cloud Agents API credentials
CURSOR_API_KEY=""
CURSOR_BASE_URL="https://api.cursor.com"
# auto | basic | bearer
CURSOR_AUTH_MODE="auto"

# Optional default quality-of-life settings
CURSOR_TIMEOUT_SECONDS="30"
CURSOR_RETRIES="2"
CURSOR_RETRY_BACKOFF_SECONDS="0.5"

# Optional OpenAI API (platform.openai.com) — not required for Cursor Cloud Agents.
# When OPENAI_API_ENABLED is 0/false/absent, integrations must not use the key.
OPENAI_API_KEY=""
OPENAI_API_ENABLED="0"

# Optional broader OpenClaw integrations (skill-specific). All optional — set only what you use.
# GitHub: fine-scoped PAT for gh / GitHub skills, OR rely on `gh auth login` (CLI session) instead.
# setup_admin.sh writes the same value to GH_TOKEN and GITHUB_TOKEN.
GH_TOKEN=""
GITHUB_TOKEN=""
GEMINI_API_KEY=""
# Telegram: optional here if your stack reads repo .env; OpenClaw may store these elsewhere.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
BRAVE_SEARCH_API_KEY=""
BRAVE_ANSWERS_API_KEY=""
MINIMAX_API_KEY=""
# Optional: CA bundle if Python reports CERTIFICATE_VERIFY_FAILED (e.g. macOS).
SSL_CERT_FILE=""

# --- Hybrid masterclass / OpenClaw enforcement (optional) ---
# Default required skills are set in scripts/andrea_openclaw_enforce.sh (core + hybrid catalog keys, including bluebubbles).
# Override only when you want a slimmer gate on a specific host:
# ANDREA_REQUIRED_OPENCLAW_SKILLS="cursor_handoff,github,gh-issues,telegram,brave-api-search"
#
# Strict: each listed skill must be OpenClaw-eligible (CLI/config satisfied). Requires jq on PATH.
# Include the native personal lanes when you want hard guarantees for messaging / notes / reminders.
# ANDREA_OPENCLAW_ELIGIBLE_SKILLS="bluebubbles,apple-notes,apple-reminders,session-logs,gog"
#
# Informational human-readable summary during enforce (non-fatal):
# ANDREA_OPENCLAW_SKILLS_CHECK=1
#
# Install/auth matrix: docs/ANDREA_OPENCLAW_HYBRID_SKILLS.md

# --- Andrea lockstep (optional local command bus) ---
# See docs/ANDREA_LOCKSTEP_ARCHITECTURE.md
# ANDREA_SYNC_DB=""
# ANDREA_SYNC_PORT=8765
# ANDREA_SYNC_TELEGRAM_SECRET=""
# Optional: Telegram Bot API webhook secret_token (sent as X-Telegram-Bot-Api-Secret-Token); query ?secret= still works as fallback.
# ANDREA_SYNC_TELEGRAM_WEBHOOK_SECRET=""
# Set ANDREA_SYNC_TELEGRAM_URL_QUERY=0 to register webhook URL without query param (header-only mode).
# ANDREA_SYNC_INTERNAL_TOKEN=""
# ANDREA_SYNC_URL="http://127.0.0.1:8765"
# Kill switch: env ANDREA_SYNC_KILL_SWITCH=1, or flag file (default <db-name>.kill next to ANDREA_SYNC_DB), or engage via API.
# ANDREA_SYNC_KILL_FILE=""
# ANDREA_SYNC_DOCTOR=0
# ANDREA_SYNC_REQUIRED=0
# Persist user-facing receipts for the Trusted Daily Assistant pack (status, reminders, lookup, goal resume).
# ANDREA_DAILY_PACK_RECEIPTS_ENABLED="1"
# ANDREA_SYNC_PUBLIC_BASE="https://andrea.example.com"
# ANDREA_SYNC_TELEGRAM_WEBHOOK_AUTOFIX="1"
# ANDREA_SYNC_TELEGRAM_WEBHOOK_AUTOFIX_INTERVAL_SECONDS="10"
# ANDREA_TELEGRAM_DELEGATE_LANE="openclaw_hybrid"
# Cursor-first lane values are treated as openclaw_hybrid (use @Cursor for explicit Cursor-primary work).
# ANDREA_SYNC_TELEGRAM_QUIET_LIFECYCLE="1"
# ANDREA_SYNC_ALEXA_EDGE_TOKEN=""
# ANDREA_SYNC_ALEXA_SUMMARY_TO_TELEGRAM="1"
# ANDREA_SYNC_ALEXA_SUMMARY_CHAT_ID=""
# ANDREA_SYNC_DELEGATED_EXECUTION_ENABLED="1"
# Enable low-noise reminder delivery from the background server thread.
# ANDREA_SYNC_PROACTIVE_SWEEP_ENABLED="1"
# ANDREA_SYNC_PROACTIVE_SWEEP_INTERVAL_SECONDS="60"
#
# Idle background optimizer (off by default): uses latest persisted experience assurance run
# as real regression evidence—no synthetic passing report. Run:
#   python3 scripts/andrea_experience_cycle.py --repo "$PWD"
# periodically so ANDREA_SYNC_BACKGROUND_OPTIMIZER_ENABLED can gate auto-heal honestly.
# ANDREA_SYNC_BACKGROUND_ENABLED="1"
# ANDREA_SYNC_BACKGROUND_OPTIMIZER_ENABLED="0"
# ANDREA_SYNC_BACKGROUND_OPTIMIZER_INTERVAL_SECONDS="900"
# ANDREA_SYNC_BACKGROUND_OPTIMIZER_IDLE_SECONDS="120"
# ANDREA_SYNC_BACKGROUND_OPTIMIZER_AUTO_APPLY="0"
# Max age (seconds) for the latest experience run to count as fresh (default 172800 = 48h).
# ANDREA_SYNC_BACKGROUND_REGRESSION_MAX_AGE_SECONDS="172800"
# ANDREA_SYNC_BACKGROUND_INCIDENT_REPAIR_ENABLED="0"
# ANDREA_SYNC_BACKGROUND_INCIDENT_CURSOR_EXECUTE="0"
# Repo and handoff mode used for Telegram-triggered Cursor work.
# ANDREA_CURSOR_REPO=""
# ANDREA_CURSOR_HANDOFF_MODE="auto"
# Override repo/mode used by the autonomous local self-heal runner.
# ANDREA_SYNC_CURSOR_REPO=""
# ANDREA_SELF_HEAL_CURSOR_MODE="auto"
# ANDREA_OPENCLAW_AGENT_ID="main"
# ANDREA_OPENCLAW_TIMEOUT_SECONDS="900"
# ANDREA_OPENCLAW_THINKING="medium"
# ANDREA_OPENCLAW_FALLBACK_TO_CURSOR="1"
# Incident repair control plane:
# ANDREA_REPAIR_ENABLED="1"
# ANDREA_REPAIR_PROMPT_VERSION="v1"
# ANDREA_REPAIR_TRIAGE_PROMPT_VERSION="v1"
# ANDREA_REPAIR_PRIMARY_PROMPT_VERSION="v1"
# ANDREA_REPAIR_CHALLENGER_PROMPT_VERSION="v1"
# ANDREA_REPAIR_DEEP_PROMPT_VERSION="v1"
# ANDREA_REPAIR_STRICT_MODEL_MATCH="0"
# ANDREA_REPAIR_SAFE_ROOTS="services/andrea_sync/:tests/:scripts/:skills/"
# ANDREA_REPAIR_CURSOR_MODE="auto"
# Optional plan-first Cursor: read-only planner agent, then executor (repair / self-heal / Telegram).
# ANDREA_CURSOR_PLAN_FIRST_ENABLED="0"
# ANDREA_REPAIR_CURSOR_PLAN_FIRST="0"
# ANDREA_SELF_HEAL_CURSOR_PLAN_FIRST="0"
# ANDREA_TELEGRAM_CURSOR_PLAN_FIRST="0"
# ANDREA_CURSOR_PLANNER_MODEL=""
# ANDREA_CURSOR_EXECUTOR_MODEL="default"
#
# Bounded collaboration / repair metadata on plan verification (default on).
# Emits COLLABORATION_RECORDED and patches plan summary when verification fails or trust-gates.
# ANDREA_SYNC_COLLABORATION_LAYER="1"
# ANDREA_SYNC_COLLAB_MAX_ROUNDS="2"
# ANDREA_SYNC_COLLAB_MAX_ROLE_CALLS="4"
# ANDREA_SYNC_COLLAB_RUNTIME_ENABLED="0"
# ANDREA_SYNC_COLLAB_ADVISORY_ONLY="1"
# ANDREA_SYNC_COLLAB_ACTION_ENABLED="0"
# Separate operator ack required before any bounded collaboration action executes (even when ACTION_ENABLED=1).
# ANDREA_SYNC_COLLAB_OPERATOR_ACTION_PROMOTION="0"
# Evidence-driven adaptive collaboration policy (activation + outcome ledgers, shadow advisory compare).
# ANDREA_SYNC_COLLAB_POLICY_ENABLED="1"
# Default on: log adaptive suppress recommendations but keep current live advisory behavior.
# ANDREA_SYNC_COLLAB_POLICY_SHADOW_ONLY="1"
# ANDREA_SYNC_COLLAB_POLICY_MIN_SAMPLE="12"
# ANDREA_SYNC_COLLAB_POLICY_MAX_WASTE_RATE="0.55"
# Optional comma-separated scenario allowlist (defaults to repoHelpVerified,verificationSensitiveAction).
# ANDREA_SYNC_COLLAB_POLICY_ALLOWLIST=""
#
# Evidence-gated collaboration promotion controller (off by default; persisted revisions + rollback).
# ANDREA_SYNC_COLLAB_PROMOTION_ENABLED="0"
# ANDREA_SYNC_COLLAB_PROMOTION_FREEZE="0"
# Comma-separated subject keys scenario|trigger (defaults: repoHelpVerified|verify_fail,repoHelpVerified|trust_gate).
# ANDREA_SYNC_COLLAB_PROMOTION_ALLOWLIST=""
# ANDREA_SYNC_COLLAB_PROMOTION_MIN_SAMPLE="20"
# ANDREA_SYNC_COLLAB_PROMOTION_MIN_USEFUL_RATE="0.60"
# ANDREA_SYNC_COLLAB_PROMOTION_MAX_HARM_RATE="0.05"
# Optional: freeze promotions when avg role_invocation_delta exceeds this (empty = disabled).
# ANDREA_SYNC_COLLAB_PROMOTION_MAX_AVG_ROLE_DELTA=""
# ANDREA_SYNC_COLLAB_ROLLBACK_ENABLED="1"
# ANDREA_SYNC_COLLAB_ROLLBACK_MAX_HARM_RATE="0.10"
# ANDREA_SYNC_COLLAB_ROLLBACK_MAX_REGRESSION_STREAK="2"
# Min executed repair_outcomes rows before bounded-action promotion is eligible.
# ANDREA_SYNC_COLLAB_BOUNDED_PROMOTION_MIN_REPAIR="10"
#
# Operator rollout HTTP (requires ANDREA_SYNC_INTERNAL_TOKEN): GET /v1/internal/rollout/candidates
# and POST /v1/internal/rollout with JSON { "action": "approve_live_advisory"|"freeze"|"rollback"|
# "promote_bounded_action"|"record_comparison"|"scenario_onboarding", "actor": "...", ... }.
# Dynamic advisory subject grants (persisted) via approve_live_advisory.grant_subject for non-static allowlist pairs.
# ANDREA_REPAIR_MAX_PATCH_ATTEMPTS="2"
# ANDREA_REPAIR_MAX_MODEL_INVOCATIONS="4"
# ANDREA_REPAIR_MAX_CHANGED_LINES="240"
# Bounded Cursor status polling + detached worktree verify after handoff (repair + self-heal reuse the same verify helper).
# ANDREA_REPAIR_CURSOR_POLL_MAX_ATTEMPTS=""
# ANDREA_REPAIR_CURSOR_POLL_INTERVAL_SECONDS=""
# ANDREA_REPAIR_POST_CURSOR_VERIFY="1"
# Optimizer / local auto-heal: unset = follow ANDREA_REPAIR_POST_CURSOR_VERIFY; 0 skips verify and apply fails closed unless policy aligned.
# ANDREA_SELF_HEAL_POST_CURSOR_VERIFY="1"
#
# Login/bootstrap helpers:
# ANDREA_OPENCLAW_SYNC_SKILLS_ON_LOGIN="1"
# ANDREA_OPENCLAW_GATEWAY_REFRESH_ON_LOGIN="1"
# Debounce duplicate login-time gateway restarts when both bootstrap and the legacy refresh agent exist.
# ANDREA_OPENCLAW_GATEWAY_RESTART_DEBOUNCE_SECONDS="25"
# ANDREA_BOOTSTRAP_SYNC_WAIT_SECONDS="90"
#
# Named Cloudflare tunnel for reboot-stable Telegram ingress:
# CLOUDFLARED_TUNNEL_TOKEN=""
#
# Fallback when cloudflared is unavailable on a host:
# ANDREA_LOCALTUNNEL_SUBDOMAIN="fine-monkeys-shake"
#
# Direct-reply memory / model tuning:
# ANDREA_DIRECT_HISTORY_TURNS="6"
# ANDREA_DIRECT_OPENAI_MODEL="gpt-4o-mini"
