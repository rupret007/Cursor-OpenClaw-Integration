# Cursor Cloud Agents API key from Cursor dashboard.
CURSOR_API_KEY=

# Optional legacy/contact field (currently not required by API auth).
CURSOR_EMAIL=

# Cursor API base URL (default is production).
CURSOR_BASE_URL=https://api.cursor.com

# Default handoff mode when --mode is omitted: auto | api | cli
OPENCLAW_CURSOR_DEFAULT_MODE=auto

# Optional local override for CLI fallback binary (agent or cursor-agent).
# CURSOR_CLI_BIN=agent

# Optional OpenAI API key (platform.openai.com). Not used by Cursor handoff unless you add features.
# OPENAI_API_ENABLED=1 | true | yes (case-insensitive) to allow use when a key is set.
OPENAI_API_KEY=
OPENAI_API_ENABLED=0
