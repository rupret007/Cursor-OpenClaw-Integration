# Cursor Cloud Agents API credentials
CURSOR_API_KEY=""
CURSOR_BASE_URL="https://api.cursor.com"
# auto | basic | bearer
CURSOR_AUTH_MODE="auto"

# Optional default quality-of-life settings
CURSOR_TIMEOUT_SECONDS="30"
CURSOR_RETRIES="2"
CURSOR_RETRY_BACKOFF_SECONDS="0.5"

# Optional OpenAI API (platform.openai.com) — not required for Cursor Cloud Agents.
# When OPENAI_API_ENABLED is 0/false/absent, integrations must not use the key.
OPENAI_API_KEY=""
OPENAI_API_ENABLED="0"

# Optional broader OpenClaw integrations (skill-specific). All optional — set only what you use.
# GitHub: fine-scoped PAT for gh / GitHub skills, OR rely on `gh auth login` (CLI session) instead.
# setup_admin.sh writes the same value to GH_TOKEN and GITHUB_TOKEN.
GH_TOKEN=""
GITHUB_TOKEN=""
GEMINI_API_KEY=""
# Telegram: optional here if your stack reads repo .env; OpenClaw may store these elsewhere.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
BRAVE_SEARCH_API_KEY=""
BRAVE_ANSWERS_API_KEY=""
MINIMAX_API_KEY=""
# Optional: CA bundle if Python reports CERTIFICATE_VERIFY_FAILED (e.g. macOS).
SSL_CERT_FILE=""
