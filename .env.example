# Cursor Cloud Agents API credentials
CURSOR_API_KEY=""
CURSOR_BASE_URL="https://api.cursor.com"
# auto | basic | bearer
CURSOR_AUTH_MODE="auto"

# Optional default quality-of-life settings
CURSOR_TIMEOUT_SECONDS="30"
CURSOR_RETRIES="2"
CURSOR_RETRY_BACKOFF_SECONDS="0.5"

# Optional OpenAI API (platform.openai.com) — not required for Cursor Cloud Agents.
# When OPENAI_API_ENABLED is 0/false/absent, integrations must not use the key.
OPENAI_API_KEY=""
OPENAI_API_ENABLED="0"
